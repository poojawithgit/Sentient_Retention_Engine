{
  "roles": {
    "admin": {
      "permissions": [
        "view:dashboard",
        "view:audit-logs",
        "view:governance-logs",
        "manage:settings",
        "manage:specialists",
        "manage:governance",
        "claim:escalation",
        "resolve:escalation",
        "execute:override"
      ],
      "inherits": ["specialist"]
    },
    "specialist": {
      "permissions": [
        "view:dashboard",
        "view:escalations",
        "claim:escalation",
        "resolve:escalation",
        "add:case-note",
        "run:retention-agent"
      ],
      "inherits": []
    }
  },
  "policies": {
    "escalation_claim_require_match": true,
    "max_composite_risk_allowed_without_override": 70,
    "require_two_factor_for_override": false,
    "allow_anonymous_simulations": false
  }
}
